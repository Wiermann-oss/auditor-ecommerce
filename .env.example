# URL base da loja (sobrescreve o config YAML se definido)
# STORE_BASE_URL=https://minimalclub.com.br

# Diretório de saída dos relatórios (default: reports/)
# REPORTS_DIR=reports

# Caminho do banco SQLite de histórico (default: auditor-history.db)
# HISTORY_DB_PATH=auditor-history.db

# Caminho do Lighthouse CLI (default: lighthouse, assumindo que está no PATH)
# LIGHTHOUSE_BIN=lighthouse

# Timeout padrão de navegação em ms (default: 30000)
# NAVIGATION_TIMEOUT_MS=30000

# Timeout padrão de elemento em ms (default: 5000)
# ELEMENT_TIMEOUT_MS=5000
